<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>IRON FORGE — Parallax Hero</title>

  <!-- GSAP + ScrollTrigger -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <!-- Google Fonts: Barlow Condensed + DM Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet" />

  <style>
    /* ─── RESET & BASE ─── */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --orange:   #ff4500;
      --cream:    #f0ece4;
      --dark:     #111010;
      --grey:     #d1d1d1;
      --font-display: 'Barlow Condensed', sans-serif;
      --font-body:    'DM Sans', sans-serif;
    }

    html {
      font-size: 16px;
      scroll-behavior: auto; /* GSAP gère le scroll */
    }

    body {
      background: var(--dark);
      color: var(--cream);
      font-family: var(--font-body);
      overflow-x: hidden;
    }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--dark); }
    ::-webkit-scrollbar-thumb { background: var(--orange); border-radius: 2px; }

    /* ════════════════════════════════════════
       HERO SECTION
    ════════════════════════════════════════ */
    .hero {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #1a1610;
    }

    /* Grain overlay */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      opacity: 0.35;
      pointer-events: none;
      z-index: 5;
    }

    /* ─── TITRE MASSIF EN FOND ─── */
    .hero-title {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(6rem, 18vw, 22rem);
      line-height: 0.85;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: transparent;
      -webkit-text-stroke: 1.5px rgba(240, 236, 228, 0.12);
      white-space: nowrap;
      user-select: none;
      z-index: 1;
      will-change: transform;
    }

    /* Highlight partiel en orange */
    .hero-title span {
      -webkit-text-stroke: 1.5px rgba(255, 69, 0, 0.25);
    }

    /* ─── META-DATA HAUT ─── */
    .meta-top {
      position: absolute;
      top: 2.5rem;
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 0 3rem;
      z-index: 10;
    }

    .meta-label {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--orange);
    }

    .meta-index {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: rgba(240, 236, 228, 0.4);
    }

    .meta-tag {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: var(--orange);
      text-align: right;
    }

    /* ─── IMAGE CENTRALE ─── */
    .island-wrapper {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: min(520px, 80vw);
      aspect-ratio: 3 / 4;
      z-index: 3;
      will-change: transform;
    }

    .island-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      border-radius: 4px;
      display: block;

      /* Ombre portée propre */
      box-shadow:
        0 40px 80px rgba(0, 0, 0, 0.7),
        0 10px 30px rgba(0, 0, 0, 0.5),
        0 0  0 1px rgba(255, 255, 255, 0.04);

      /* Léger vignette interne */
      mask-image: linear-gradient(
        to bottom,
        rgba(0,0,0,1) 60%,
        rgba(0,0,0,0.6) 85%,
        rgba(0,0,0,0) 100%
      );
      -webkit-mask-image: linear-gradient(
        to bottom,
        rgba(0,0,0,1) 60%,
        rgba(0,0,0,0.6) 85%,
        rgba(0,0,0,0) 100%
      );
    }

    /* Reflet en bas de l'image */
    .island-wrapper::after {
      content: '';
      position: absolute;
      bottom: -60px;
      left: 10%;
      right: 10%;
      height: 60px;
      background: linear-gradient(
        to bottom,
        rgba(255, 69, 0, 0.06) 0%,
        transparent 100%
      );
      filter: blur(20px);
      border-radius: 50%;
    }

    /* ─── META-DATA BAS ─── */
    .meta-bottom {
      position: absolute;
      bottom: 2.5rem;
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding: 0 3rem;
      z-index: 10;
    }

    .meta-coords {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: rgba(240, 236, 228, 0.3);
      line-height: 1.8;
    }

    .meta-scroll-hint {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: var(--orange);
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }

    .scroll-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, var(--orange), transparent);
      animation: scroll-pulse 2s ease-in-out infinite;
    }

    @keyframes scroll-pulse {
      0%, 100% { opacity: 0.3; transform: scaleY(1); }
      50%       { opacity: 1;   transform: scaleY(1.15); }
    }

    .meta-edition {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: rgba(240, 236, 228, 0.3);
      text-align: right;
      line-height: 1.8;
    }

    /* Ligne décorative centrale */
    .hero-line {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 1px;
      background: linear-gradient(
        to bottom,
        transparent 0%,
        rgba(255, 69, 0, 0.15) 20%,
        rgba(255, 69, 0, 0.15) 80%,
        transparent 100%
      );
      z-index: 2;
      pointer-events: none;
    }

    /* ════════════════════════════════════════
       CONTENT SECTION
    ════════════════════════════════════════ */
    .content {
      position: relative;
      width: 100%;
      min-height: 100vh;
      background: var(--grey);
      z-index: 20;
      display: grid;
      grid-template-columns: 1fr 1fr;
      overflow: hidden;
    }

    /* Bande orange décorative en haut */
    .content::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--orange);
    }

    .content-left {
      padding: 6rem 4rem 6rem 6rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-right: 1px solid rgba(17, 16, 16, 0.1);
    }

    .content-eyebrow {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 2rem;
    }

    .content-heading {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(3.5rem, 6vw, 7rem);
      line-height: 0.9;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--dark);
      margin-bottom: 2.5rem;
    }

    .content-heading em {
      font-style: normal;
      color: var(--orange);
      display: block;
    }

    .content-body {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(17, 16, 16, 0.6);
      max-width: 36ch;
      margin-bottom: 3rem;
    }

    .content-cta {
      display: inline-flex;
      align-items: center;
      gap: 1rem;
      background: var(--orange);
      color: #fff;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 1rem 2rem;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background 0.2s;
      width: fit-content;
    }

    .content-cta:hover { background: #e03d00; }

    .content-cta svg {
      transition: transform 0.2s;
    }

    .content-cta:hover svg {
      transform: translateX(4px);
    }

    .content-right {
      padding: 6rem 6rem 6rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      margin-top: auto;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .stat-number {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: clamp(2.5rem, 4vw, 4.5rem);
      line-height: 1;
      color: var(--dark);
    }

    .stat-number sup {
      font-size: 0.4em;
      vertical-align: super;
      color: var(--orange);
    }

    .stat-label {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(17, 16, 16, 0.45);
    }

    .content-quote {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(1.2rem, 2vw, 1.7rem);
      line-height: 1.3;
      text-transform: uppercase;
      color: var(--dark);
      padding-top: 4rem;
      border-top: 1px solid rgba(17, 16, 16, 0.15);
    }

    .content-quote span { color: var(--orange); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      .content {
        grid-template-columns: 1fr;
      }

      .content-left {
        padding: 5rem 2rem 3rem;
        border-right: none;
        border-bottom: 1px solid rgba(17, 16, 16, 0.1);
      }

      .content-right {
        padding: 3rem 2rem 5rem;
      }

      .stat-grid {
        gap: 2rem;
      }

      .meta-top, .meta-bottom {
        padding: 0 1.5rem;
      }

      .hero-title {
        font-size: clamp(5rem, 22vw, 10rem);
      }

      .island-wrapper {
        width: 75vw;
      }
    }

    /* ─── ENTRY ANIMATION ─── */
    .hero-title,
    .island-wrapper,
    .meta-top,
    .meta-bottom {
      opacity: 0;
    }
  </style>
</head>
<body>

  <!-- ════════════ HERO ════════════ -->
  <section class="hero">

    <!-- Ligne centrale décorative -->
    <div class="hero-line"></div>

    <!-- Meta haut -->
    <div class="meta-top">
      <div>
        <div class="meta-label">Iron Forge</div>
        <div class="meta-index">Performance Studio — Paris</div>
      </div>
      <div class="meta-tag">
        Est. 2024<br />
        Season 01
      </div>
    </div>

    <!-- Titre massif fond -->
    <h1 class="hero-title">IRON<span>FORGE</span></h1>

    <!-- Image centrale -->
    <div class="island-wrapper">
      <img
        src="https://images.unsplash.com/photo-1526506118085-60ce8714f8c5?w=800&q=85&auto=format&fit=crop"
        alt="Athlète en deadlift — performance maximale"
        width="520"
        height="693"
        fetchpriority="high"
      />
    </div>

    <!-- Meta bas -->
    <div class="meta-bottom">
      <div class="meta-coords">
        48°51′N 2°21′E<br />
        Élévation — 35m
      </div>
      <div class="meta-scroll-hint">
        <div class="scroll-line"></div>
        Scroll
      </div>
      <div class="meta-edition">
        Collection 2024<br />
        Vol. 01 / 12
      </div>
    </div>

  </section>

  <!-- ════════════ CONTENT ════════════ -->
  <section class="content">

    <div class="content-left">
      <div class="content-eyebrow">Programme Signature</div>
      <h2 class="content-heading">
        Forge<br />
        <em>Ton</em>
        Héritage
      </h2>
      <p class="content-body">
        Un programme bâti sur les principes fondamentaux de la force brute. Pas de compromis, pas de raccourcis — seulement la progression systématique vers ta version la plus aboutie.
      </p>
      <a href="#" class="content-cta">
        Découvrir le programme
        <svg width="16" height="12" viewBox="0 0 16 12" fill="none">
          <path d="M0 6H14M9 1L14 6L9 11" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="content-right">
      <div class="content-quote">
        «&nbsp;La force ne se demande pas,<br/>
        <span>elle se construit.</span>&nbsp;»
      </div>
      <div class="stat-grid">
        <div class="stat-item">
          <div class="stat-number">12<sup>sem</sup></div>
          <div class="stat-label">Durée programme</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">4<sup>×</sup></div>
          <div class="stat-label">Sessions/semaine</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">+38<sup>%</sup></div>
          <div class="stat-label">Gain de force moyen</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">2K<sup>+</sup></div>
          <div class="stat-label">Athlètes formés</div>
        </div>
      </div>
    </div>

  </section>

  <script>
    // ─── GSAP REGISTRATION ───
    gsap.registerPlugin(ScrollTrigger);

    // ─── ENTRY ANIMATION (page load) ───
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    tl.to('.meta-top',       { opacity: 1, y: 0, duration: 0.8, delay: 0.2 })
      .to('.hero-title',     { opacity: 1, duration: 1 }, '-=0.4')
      .to('.island-wrapper', { opacity: 1, y: 0, duration: 1, ease: 'power2.out' }, '-=0.6')
      .to('.meta-bottom',    { opacity: 1, duration: 0.8 }, '-=0.5');

    // ─── PARALLAX SCROLL ───
    // 1. H1 remonte rapidement
    gsap.to('.hero-title', {
      yPercent: -150,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      }
    });

    // 2. Image centrale remonte plus lentement
    gsap.to('.island-wrapper', {
      yPercent: -50,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      }
    });

    // 3. Léger zoom sur l'image (impression caméra)
    gsap.to('.island-wrapper img', {
      scale: 1.1,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      }
    });

    // 4. Méta-données se dissipent
    gsap.to(['.meta-top', '.meta-bottom'], {
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: '40% top',
        scrub: 1,
      }
    });

    // 5. Ligne décorative se dissipe
    gsap.to('.hero-line', {
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: '30% top',
        scrub: 1,
      }
    });

    // 6. Content remonte pour recouvrir le hero
    //    (translateY initial de 100px → 0, géré avec fromTo)
    gsap.fromTo('.content',
      { y: 0 },
      {
        y: 0, // La section remonte naturellement grâce au scroll normal
        ease: 'none',
        scrollTrigger: {
          trigger: '.content',
          start: 'top bottom',
          end: 'top top',
          scrub: 1,
        }
      }
    );

    // Entrée des éléments content au scroll
    gsap.fromTo('.content-eyebrow',
      { opacity: 0, y: 30 },
      {
        opacity: 1, y: 0, duration: 0.8,
        scrollTrigger: {
          trigger: '.content',
          start: 'top 80%',
          toggleActions: 'play none none reverse',
        }
      }
    );

    gsap.fromTo('.content-heading',
      { opacity: 0, y: 50 },
      {
        opacity: 1, y: 0, duration: 1, delay: 0.15,
        scrollTrigger: {
          trigger: '.content',
          start: 'top 80%',
          toggleActions: 'play none none reverse',
        }
      }
    );

    gsap.fromTo(['.content-body', '.content-cta'],
      { opacity: 0, y: 30 },
      {
        opacity: 1, y: 0, duration: 0.8, stagger: 0.15, delay: 0.3,
        scrollTrigger: {
          trigger: '.content',
          start: 'top 75%',
          toggleActions: 'play none none reverse',
        }
      }
    );

    gsap.fromTo('.stat-item',
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0, duration: 0.7, stagger: 0.1, delay: 0.2,
        scrollTrigger: {
          trigger: '.stat-grid',
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        }
      }
    );

    gsap.fromTo('.content-quote',
      { opacity: 0, x: -20 },
      {
        opacity: 1, x: 0, duration: 0.8,
        scrollTrigger: {
          trigger: '.content-quote',
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        }
      }
    );
  </script>

</body>
</html>
